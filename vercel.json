{
  "crons": [
    {
      "path": "/api/cron/cancel-expired",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/run-attestations",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/refresh-sanctions",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/send-reminders",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/progress-checkins",
      "schedule": "0 9 * * 2"
    },
    {
      "path": "/api/cron/pulse-checks",
      "schedule": "0 7 * * 1"
    }
  ],
  "functions": {
    "src/app/api/verify/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/proof/upload/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/escrow/create/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/escrow/finish/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/escrow/cancel/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/escrow/webhook/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/cron/run-attestations/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/contracts/[id]/milestones/[milestoneId]/attestation/run/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/pulse-checks/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/reports/board-pack/route.ts": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://cascrow.xyz" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
