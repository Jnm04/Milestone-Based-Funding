generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String     @id @default(cuid())
  email            String     @unique
  passwordHash     String
  name             String?
  role             Role
  walletAddress    String?    @unique
  companyName      String?
  department       String?
  jobTitle         String?
  phone            String?
  bio              String?
  website          String?
  contracts        Contract[] @relation("investor")
  startupContracts Contract[] @relation("startup")
  createdAt        DateTime   @default(now())

  // Email verification
  emailVerified                Boolean   @default(false)
  emailVerificationToken       String?   @unique
  emailVerificationTokenExpiry DateTime?

  // Email notification preferences
  notifyProofSubmitted  Boolean @default(true)  // Investor: startup submitted proof
  notifyPendingReview   Boolean @default(true)  // Investor: AI needs manual review
  notifyMilestoneCompleted Boolean @default(true) // Investor: milestone fully completed
  notifyFunded          Boolean @default(true)  // Startup: milestone was funded
  notifyVerified        Boolean @default(true)  // Startup: proof approved, funds released
  notifyRejected        Boolean @default(true)  // Startup: proof rejected by AI

  // Brute-force protection
  loginAttempts   Int       @default(0)
  lockoutUntil    DateTime?

  // Password reset
  passwordResetToken       String?   @unique
  passwordResetTokenExpiry DateTime?

  // Enterprise Attestation Mode access
  isEnterprise       Boolean   @default(false)
  enterpriseActivatedAt DateTime?

  // KYC tiers: 0=email only ($1k limit), 1=sanctions CLEAR ($10k), 2=manual KYC ($100k), 3=KYB (unlimited)
  kycTier            Int       @default(0)

  // Sanctions screening (KYC Tier 1)
  dateOfBirth        DateTime? // Optional — used to reduce false positives in sanctions screening
  sanctionsCheckedAt DateTime?
  sanctionsStatus    String?   // "CLEAR" | "HIT" | "PENDING"

  // Telegram notifications
  telegramChat     TelegramChat?

  // Outbound webhooks
  webhookEndpoints WebhookEndpoint[]

  // API keys for programmatic access
  apiKeys          ApiKey[]

  // Organization / team members
  ownedOrgMembers  OrgMember[] @relation("OrgOwner")
  orgMemberships   OrgMember[] @relation("OrgMember")

  // Feature Y: Stakeholder Transparency Report — cached per quarter
  lastTransparencyReportUrl    String?
  lastTransparencyReportPeriod String?   // e.g. "Q1-2026"

  // Phase 3 — Feature VII: Double Materiality Wizard
  materialityAssessments MaterialityAssessment[]

  // Feature 7: Startup public profile
  publicProfile      Boolean @default(false)
  publicUsername     String? @unique
  companyBio         String?
  companyWebsite     String?
  linkedinUrl        String?
  verifiedBadgeNftId String?

  // Feature 3: Slack/Teams integrations
  notificationIntegrations NotificationIntegration[]

  // Feature 6: Contract templates
  contractTemplates  ContractTemplate[]

  // Feature 2: Multi-entity organisation
  organisation       Organisation?

  // Feature 5: Deal Rooms
  dealRoomsAsInvestor DealRoom[] @relation("DealRoomInvestor")

  // 2FA / TOTP
  totpSecret   String?
  totpEnabled  Boolean  @default(false)

  // In-app notifications
  notifications Notification[]

  // Feature 11: Audit partner + client access
  auditorPartner      AuditorPartner?
  auditorClientAccesses AuditorClientAccess[] @relation("AuditorAccessClient")
}

enum Role {
  INVESTOR
  STARTUP
}

model Contract {
  id                  String         @id @default(cuid())
  investorId          String
  investor            User           @relation("investor", fields: [investorId], references: [id])
  startupId           String?
  startup             User?          @relation("startup", fields: [startupId], references: [id])
  milestone           String
  amountUSD           Decimal
  amountRLUSD         String?
  status              ContractStatus @default(DRAFT)
  escrowSequence      Int?
  escrowCondition     String?
  escrowFulfillment   String?
  evmTxHash           String?   // EVM: tx hash of the fundMilestone transaction
  nftTokenId          String?   // XRPL: NFT token ID minted on completion
  nftTxHash           String?   // XRPL: tx hash of the NFTokenMint transaction
  nftImageUrl         String?   // XRPL: public URL of the certificate SVG image
  cancelAfter         DateTime
  inviteLink          String?        @unique
  /// [{severity: "WARNING"|"INFO", text: string}] — structural risk flags generated at contract creation
  riskFlags           Json?
  /// Feature K: AI-generated single-sentence deal health note, cached 24h
  healthNote          String?        @db.Text
  healthNoteUpdatedAt DateTime?
  /// "ESCROW" | "ATTESTATION" — attestation mode skips all financial/crypto flows
  mode                String         @default("ESCROW")
  /// Optional auditor email — CC'd on attestation results, read-only access
  auditorEmail        String?
  /// Enterprise approval workflow — when true, milestones must be approved before AI verification runs
  requiresApproval    Boolean  @default(false)
  proofs              Proof[]
  milestones          Milestone[]
  auditLogs           AuditLog[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([investorId])
  @@index([startupId])
}

enum ContractStatus {
  DRAFT
  AWAITING_ESCROW
  FUNDED
  PROOF_SUBMITTED
  PENDING_REVIEW
  VERIFIED
  REJECTED
  DECLINED
  RENEGOTIATING
  EXPIRED
  COMPLETED
}

model Proof {
  id            String     @id @default(cuid())
  contractId    String
  contract      Contract   @relation(fields: [contractId], references: [id])
  milestoneId   String?
  milestone     Milestone? @relation(fields: [milestoneId], references: [id])
  fileUrl       String
  fileName      String
  fileHash      String?    // SHA-256 of the uploaded file — written on-chain via audit log
  extractedText String?    @db.Text
  aiDecision    String?
  aiReasoning   String?    @db.Text
  aiConfidence  Int?
  /// [{model, decision, confidence, reasoning}] — individual votes from each AI model
  aiModelVotes  Json?
  /// "file" | "github_url" — how the proof was submitted
  proofType     String     @default("file")
  /// For github_url proofs: the submitted GitHub repo URL
  proofUrl      String?
  /// [{code, description}] — structured rejection reasons generated at rejection time
  aiObjections  Json?
  /// Appeal filed by the startup after AI rejection
  appealStatus    String?    // null = no appeal | "APPROVED" = overturned → PENDING_REVIEW | "REJECTED" = upheld
  appealText      String?    @db.Text
  appealResult    String?    // "OVERTURNED" | "UPHELD"
  appealReasoning String?    @db.Text
  appealedAt      DateTime?
  /// [{type: string, severity: "WARNING"|"RED_FLAG", detail: string}] — fraud pre-screen flags (run before 5-model vote)
  authenticityFlags Json?
  /// 0–100 authenticity score: 100 = no flags, -30 per RED_FLAG, -15 per WARNING
  authenticityScore Int?
  /// Feature V: AI-generated bullet summary of proof contents (JSON-encoded string[])
  aiContentSummary  String?  @db.Text
  /// Feature W: AI-generated resubmission diff (JSON: {addressed: string[], stillOpen: string[]})
  aiResubmissionDiff  String?  @db.Text
  createdAt     DateTime   @default(now())

  @@index([contractId])
  @@index([milestoneId])
}

model Milestone {
  id                String          @id @default(cuid())
  contractId        String
  contract          Contract        @relation(fields: [contractId], references: [id])
  title             String
  description       String?        @db.Text
  amountUSD         Decimal
  amountRLUSD       String?
  cancelAfter       DateTime
  status            MilestoneStatus @default(PENDING)
  order             Int
  escrowSequence    Int?
  escrowCondition   String?
  escrowFulfillment String?
  evmTxHash         String?   // EVM: tx hash of the fundMilestone transaction
  nftTokenId        String?   // XRPL: NFT token ID minted on completion
  nftTxHash         String?   // XRPL: tx hash of the NFTokenMint transaction
  nftImageUrl       String?   // XRPL: public URL of the certificate SVG image
  proofs            Proof[]

  // Feature D: AI Proof Guidance — generated once, cached permanently
  proofGuidance         Json?      // { tone: string, checklist: [{ item, why }] }
  proofGuidanceCachedAt DateTime?

  // Feature F: AI Milestone Renegotiation
  /// "RENEGOTIATING" | "EXTENSION_REQUESTED" | "EXTENSION_APPROVED" | "EXTENSION_REJECTED"
  renegotiationStatus   String?
  /// When the 48-hour renegotiation window closes
  renegotiationDeadline DateTime?
  interimUpdateText     String?    @db.Text
  interimUpdateFileUrl  String?
  interimUpdateFileName String?
  /// Haiku plausibility assessment (2-sentence summary)
  interimAiAssessment   String?    @db.Text
  /// true = plausible completion, false = unlikely
  interimAiPositive     Boolean?
  /// How many extra days the startup requested (7 | 14 | 30)
  extensionDays         Int?
  extensionApprovedAt   DateTime?

  // Feature G: AI Progress Check-ins
  progressUpdates   ProgressUpdate[]

  // Feature H: AI Reputation System
  /// AI-generated privacy-safe summary of this milestone's achievement (no names, URLs, revenue figures)
  reputationSummary  String?   @db.Text
  /// Startup opted in to show this card on their public profile (default: private)
  reputationPublic   Boolean   @default(false)
  /// "MVP" | "REVENUE" | "PARTNERSHIP" | "GITHUB" | "BETA" | "OTHER"
  reputationCategory String?

  // Feature L: AI Completion Report
  /// AI-generated 2-3 sentence narrative for the completion report
  completionNarrative   String?   @db.Text
  completionNarrativeAt DateTime?

  // Enterprise Attestation Mode — data source (defined before verification date, locked)
  /// "URL_SCRAPE" | "REST_API" | "FILE_UPLOAD" | "MANUAL_REVIEW"
  dataSourceType          String?
  /// URL to scrape or REST API endpoint
  dataSourceUrl           String?
  /// AES-256-GCM encrypted API key (enc:<iv>:<ct>:<tag>), stored only if REST_API
  dataSourceApiKeyEnc     String?   @db.Text
  /// Last 4 chars of API key — shown in UI for confirmation, never the full key
  dataSourceApiKeyHint    String?
  /// Additional config: { method, headers, responsePath } for REST_API
  dataSourceConfig        Json?
  /// When the source was locked — no edits allowed after this point
  dataSourceLockedAt      DateTime?

  // Enterprise Attestation Mode — results (written after platform fetch)
  attestationFetchedAt    DateTime?
  /// SHA-256 of the raw fetched response
  attestationFetchedHash  String?
  /// Vercel Blob URL of the raw fetched content (for audit, never shown to owner)
  attestationFetchedBlob  String?
  /// URL of the generated attestation certificate PDF
  attestationCertUrl      String?

  // Recurring schedule
  /// "ONE_OFF" | "MONTHLY" | "QUARTERLY" | "ANNUAL"
  scheduleType            String?
  scheduleNextRun         DateTime?
  schedulePreviousRun     DateTime?

  // Regulatory mapping — JSON array of tag strings e.g. ["CSRD:E1", "GRI:305-1"]
  regulatoryTags          String?   @db.Text

  // Feature II: Early Warning / Pulse Checks — lightweight trend monitoring between official runs
  /// Whether pulse checks are active for this milestone (recurring schedules only)
  pulseCheckEnabled       Boolean   @default(false)
  /// "MID_PERIOD" | "WEEKLY" | "BIWEEKLY"
  pulseCheckInterval      String?
  lastPulseCheckAt        DateTime?
  /// "ON_TRACK" | "AT_RISK" | "LIKELY_MISS"
  lastPulseCheckRisk      String?

  // Feature V: Peer Benchmarking — opt-in anonymized percentile comparison
  benchmarkOptIn          Boolean   @default(false)
  /// "MANUFACTURING" | "TECH" | "FINANCE" | "ENERGY" | "HEALTHCARE" | "RETAIL" | "OTHER"
  benchmarkSector         String?

  // Phase 3 — Feature VI: Predictive Miss Detection
  /// "YES" | "NO" | "INCONCLUSIVE" — current AI prediction based on pulse-check trend
  predictedOutcome        String?
  /// 0.0–1.0 confidence from linear regression R² × avg snapshot confidence
  predictedConfidence     Float?
  predictedUpdatedAt      DateTime?

  // Phase 3 — Feature X: Enterprise System Connectors
  /// "SAP" | "WORKDAY" | "SALESFORCE" | "NETSUITE" — set when dataSourceType=ENTERPRISE_CONNECTOR
  dataSourceConnector     String?

  // Phase 3 — Feature XI: Multi-Party Consensus
  consensusEnabled        Boolean   @default(false)
  /// M — minimum YES votes required (AI + humans combined)
  consensusThreshold      Int?
  /// "AWAITING_VOTES" | "REACHED" | "FAILED" | "TIMED_OUT"
  consensusStatus         String?
  consensusDeadline       DateTime?

  attestationEntries AttestationEntry[]
  pulseSnapshots     PulseCheckSnapshot[]
  consensusVotes     ConsensusVote[]

  // Feature 4: Connector Health Monitoring
  connectorLastHealthy DateTime?
  connectorStatus      String?   @default("UNKNOWN") // "OK" | "ERROR" | "UNKNOWN"

  // Feature 10: Confidential Attestation Mode
  isConfidential  Boolean @default(false)
  encryptedGoal   String? @db.Text // AES-256-GCM encrypted JSON {title, description}
  goalHash        String?           // sha256(title + description + salt) — anchored on-chain

  // Custom AI verification criteria (enterprise: override default prompt rubric)
  verificationCriteria String? @db.Text

  // Milestone dependency — this milestone cannot be funded until the dependency is COMPLETED
  dependsOnMilestoneId String?

  // Enterprise internal approval workflow
  internalApprovalStatus  String?    // null | "APPROVED" | "REJECTED"
  internalApprovedBy      String?    // name of approver (denormalised for display)
  internalApprovedAt      DateTime?
  internalApprovalNote    String?    @db.Text

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([contractId])
}

/// One attestation run result for a milestone.
/// Created by the platform runner on each scheduled or manual run.
model AttestationEntry {
  id            String    @id @default(cuid())
  milestoneId   String
  milestone     Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  /// e.g. "2026-Q1", "2026-04", "2026" — identifies the period being attested
  period        String
  fetchedAt     DateTime
  fetchedHash   String
  fetchedBlobUrl String?
  /// "YES" | "NO" | "INCONCLUSIVE"
  aiVerdict     String
  aiReasoning   String    @db.Text
  xrplTxHash    String?
  certUrl       String?
  /// "PLATFORM" | "AUDITOR_RERUN"
  type          String    @default("PLATFORM")
  /// For AUDITOR_RERUN: points to the original PLATFORM entry
  linkedEntryId String?
  auditorEmail  String?
  /// Feature I: AI-generated regulatory mapping [{framework, article, clause, confidence}]
  regulatoryMapping Json?
  /// Phase 3 — Feature IX: Cryptographic Evidence Chain
  /// {step0, step1, step2, step3, promptHash, systemPromptVersion, chainRoot}
  evidenceChain Json?
  createdAt     DateTime  @default(now())

  @@index([milestoneId])
}

/// Voluntary progress updates logged by the startup while a milestone is FUNDED.
/// Created via POST /api/contracts/[id]/milestones/[milestoneId]/progress
/// or automatically prompted by the weekly progress-checkins cron.
model ProgressUpdate {
  id          String    @id @default(cuid())
  milestoneId String
  milestone   Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  text        String    @db.Text
  /// "MANUAL" = startup typed it in the UI
  source      String    @default("MANUAL")
  createdAt   DateTime  @default(now())

  @@index([milestoneId])
}

enum MilestoneStatus {
  PENDING
  AWAITING_ESCROW
  FUNDED
  PROOF_SUBMITTED
  PENDING_REVIEW
  VERIFIED
  REJECTED
  RENEGOTIATING
  EXPIRED
  COMPLETED
}

model AuditLog {
  id          String   @id @default(cuid())
  contractId  String
  contract    Contract @relation(fields: [contractId], references: [id])
  milestoneId String?
  event       String
  evmTxHash   String?
  xrplTxHash  String?
  actor       String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([contractId])
}

// ── Brain / ML ───────────────────────────────────────────────────────────────

/// Labeled training example. AUTO entries come from high-consensus AI votes (4-1 or 5-0).
/// HUMAN entries come from internal manual labeling of 3-2 splits or flagged fraud.
model TrainingEntry {
  id             String   @id @default(cuid())
  proofId        String
  milestoneText  String   @db.Text
  proofText      String   @db.Text
  /// APPROVED | REJECTED | FAKED
  label          String
  /// AUTO_5_0 | AUTO_4_1 | HUMAN | GRANT_GIVER
  labelSource    String
  /// AI_GENERATED | MANIPULATED | RECYCLED | IMPLAUSIBLE — only set when label=FAKED
  fraudType      String?
  /// [{model, decision, confidence, reasoning}]
  modelVotes     Json
  /// Number of YES votes among the 5 models (0–5)
  consensusLevel Int
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
}

/// Holds 3-2 split verifications for internal human review before adding to TrainingEntry.
model HumanReviewQueue {
  id             String    @id @default(cuid())
  proofId        String    @unique
  milestoneText  String    @db.Text
  proofText      String    @db.Text
  /// Original file URL (S3/Blob) so reviewer can open the actual PDF/image
  fileUrl        String?
  modelVotes     Json
  consensusLevel Int
  reviewedAt     DateTime?
  /// Set when reviewer clicks Skip — excluded from pending list
  skippedAt      DateTime?
  /// Set after human labels this entry
  label          String?
  fraudType      String?
  notes          String?   @db.Text
  createdAt      DateTime  @default(now())

  @@index([label])
}

/// Tracks token usage and estimated cost for every AI API call made by the platform.
/// Used for the internal usage/cost dashboard.
model ApiUsage {
  id               String   @id @default(cuid())
  /// Display name: "Claude Haiku" | "GPT-4o-mini" | "Gemini Flash" | "Mistral Small" | "Cerebras/Qwen3" | "Embedding"
  model            String
  inputTokens      Int
  outputTokens     Int
  /// Estimated cost in USD based on known pricing at time of implementation
  estimatedCostUsd Float
  /// "verification" | "generation" | "embedding"
  context          String   @default("verification")
  createdAt        DateTime @default(now())

  @@index([model])
  @@index([createdAt])
}

/// Text embedding for each proof — used for RAG context in AI verification.
/// Embedding stored as JSON-encoded float array (migrates to pgvector later).
model ProofEmbedding {
  id        String   @id @default(cuid())
  proofId   String   @unique
  /// JSON-encoded float[] from text-embedding-3-small (1536 dims)
  embedding String   @db.Text
  model     String   @default("text-embedding-3-small")
  createdAt DateTime @default(now())
}

// ── Webhooks ─────────────────────────────────────────────────────────────────

/// Outbound webhook endpoint registered by a user.
/// Cascrow sends a signed POST to this URL on every subscribed event.
model WebhookEndpoint {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  url       String
  /// HMAC-SHA256 secret — used to sign the request body
  secret    String
  /// JSON array of subscribed event names, e.g. ["contract.funded","proof.submitted"]
  events    String   @db.Text
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([userId])
}

// ── Telegram ──────────────────────────────────────────────────────────────────

/// One-to-one: a user's connected Telegram chat.
/// Linked via a short-lived deep-link token at /api/telegram/connect.
model TelegramChat {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatId      String    // Telegram numeric chat ID (stored as string)
  active      Boolean   @default(true)
  /// Pending connection token (hex, 32 bytes). Cleared after /start is confirmed.
  connectToken       String?   @unique
  connectTokenExpiry DateTime?
  createdAt   DateTime  @default(now())
}

// ── Reputation ────────────────────────────────────────────────────────────────

/// Aggregated AI reputation score for a startup user.
/// Recalculated on every milestone completion. One row per startup.
model ReputationScore {
  id               String   @id @default(cuid())
  userId           String   @unique
  totalCompleted   Int      @default(0)
  /// 0.0–1.0 ratio of milestones completed on or before their deadline
  onTimeRate       Float?
  /// Average AI confidence score across all verified milestones (0–100)
  avgAiConfidence  Float?
  /// Average number of proof submissions before approval
  avgResubmissions Float?
  /// JSON object: { MVP: 2, REVENUE: 1, PARTNERSHIP: 0, GITHUB: 1, BETA: 0, OTHER: 0 }
  categories       Json
  lastCalculatedAt DateTime @default(now())

  @@index([userId])
}

// ── Credibility ───────────────────────────────────────────────────────────────

/// AI-generated credibility score for a startup on a specific contract.
/// Generated on demand by the investor, cached for 7 days.
model CredibilityScore {
  id         String   @id @default(cuid())
  startupId  String
  contractId String
  score      Int                // 0-100
  tier       String             // "HIGH" | "MEDIUM" | "LOW"
  signals    Json               // [{label, value, positive}]
  summary    String   @db.Text
  rawSignals Json               // raw data for audit/debugging
  cachedAt   DateTime @default(now())
  createdAt  DateTime @default(now())

  @@unique([startupId, contractId])
  @@index([startupId])
  @@index([contractId])
}

// ── Counter-Proposal ─────────────────────────────────────────────────────────

/// Pre-funding term negotiation: startup proposes changes before accepting invite.
/// One record per contract (unique). status: "PENDING" | "ACCEPTED" | "REJECTED"
model CounterProposal {
  id                  String    @id @default(cuid())
  contractId          String    @unique
  /// The startup user who submitted the counter-proposal
  proposedBy          String
  /// "PENDING" | "ACCEPTED" | "REJECTED"
  status              String    @default("PENDING")
  /// [{milestoneId, title, origAmountUSD, origCancelAfter, newAmountUSD?, newCancelAfter?}]
  milestoneChanges    Json
  /// The startup's written rationale (min 50 chars)
  rationale           String    @db.Text
  /// Optional AI-polished version of the rationale (Haiku)
  aiImprovedRationale String?   @db.Text
  respondedAt         DateTime?
  createdAt           DateTime  @default(now())

  @@index([contractId])
  @@index([proposedBy])
}

// ── Enterprise Reports ────────────────────────────────────────────────────────

/// Board-ready PDF reports generated from verified AttestationEntry records.
/// Created by POST /api/reports/board-pack.
model Report {
  id          String   @id @default(cuid())
  contractId  String
  /// "2026", "2026-Q1", "2026-04", etc.
  period      String
  /// "BOARD_PACK"
  type        String   @default("BOARD_PACK")
  /// Vercel Blob URL of the generated HTML/PDF
  blobUrl     String
  generatedAt DateTime @default(now())

  @@index([contractId])
}

// ── Enterprise Waitlist ───────────────────────────────────────────────────────

/// Interest registrations from companies wanting early access to Attestation Mode.
model EnterpriseWaitlist {
  id             String   @id @default(cuid())
  name           String
  email          String
  company        String
  useCase        String   // "CSRD" | "KPI" | "COMPLIANCE" | "OTHER"
  message        String?  @db.Text
  preActivated   Boolean  @default(false) // true = admin approved before account exists
  createdAt      DateTime @default(now())

  @@index([email])
}

// ── Sanctions ─────────────────────────────────────────────────────────────────

/// Cached sanctions list snapshots.
/// Updated daily by /api/cron/refresh-sanctions.
model SanctionsCache {
  id          String   @id @default(cuid())
  /// "OFAC_SDN" | "EU_CONSOLIDATED" (reserved for future lists)
  listName    String   @unique
  /// JSON array of normalized name strings extracted from the list
  entries     String   @db.Text
  /// ISO timestamp of the list publication date (from the source)
  publishedAt String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

// ── Phase 3: Feature VI — Predictive Miss Detection ───────────────────────────

/// Stores every pulse-check snapshot for trend analysis.
/// Used by predictor.service.ts to compute regression-based predictions.
model PulseCheckSnapshot {
  id          String   @id @default(cuid())
  milestoneId String
  milestone   Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  capturedAt  DateTime  @default(now())
  /// "ON_TRACK" | "AT_RISK" | "LIKELY_MISS"
  risk        String
  /// Extracted metric value as a string, e.g. "€4.2M"
  rawValue    String?
  /// Target value at time of check, e.g. "€5M"
  targetValue String?
  /// AI confidence in the extracted value (0.0–1.0)
  confidence  Float

  @@index([milestoneId, capturedAt])
}

// ── Phase 3: Feature VII — Double Materiality Wizard ─────────────────────────

/// CSRD double-materiality assessment for a company.
/// Created by the wizard flow at /enterprise/materiality/[id].
model MaterialityAssessment {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Optional link to an existing attestation contract
  contractId String?
  /// "MANUFACTURING" | "TECH" | "FINANCE" | "ENERGY" | "HEALTHCARE" | "RETAIL" | "OTHER"
  sector     String
  /// Wizard Q&A: [{question, answer}]
  answers    Json     @default("[]")
  /// Materiality matrix: [{topic, financialScore, impactScore, material, esrsArticles, griStandards, rationale}]
  matrix     Json?
  /// AI-generated 2-paragraph executive summary
  summary    String?  @db.Text
  /// "IN_PROGRESS" | "COMPLETE"
  status     String   @default("IN_PROGRESS")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([contractId])
}

// ── API Keys ──────────────────────────────────────────────────────────────────

/// API key for programmatic access to the enterprise API.
/// The full key is shown once at creation and never stored — only its SHA-256 hash is kept.
model ApiKey {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  /// SHA-256(fullKey) — used to authenticate incoming requests
  keyHash     String    @unique
  /// First 8 chars of the key — shown in UI as identifier, never the full key
  keyPrefix   String
  lastUsedAt  DateTime?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([keyHash])
}

// ── Organization / Team Members ───────────────────────────────────────────────

/// A colleague invited to view an enterprise account's attestation data.
/// ownerId = the enterprise account; memberId = the invited colleague (set after acceptance).
model OrgMember {
  id           String    @id @default(cuid())
  ownerId      String
  owner        User      @relation("OrgOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  email        String
  name         String?
  /// "VIEWER" | "EDITOR"
  role         String    @default("VIEWER")
  inviteToken  String?   @unique
  inviteExpiry DateTime?
  memberId     String?
  member       User?     @relation("OrgMember", fields: [memberId], references: [id], onDelete: SetNull)
  acceptedAt   DateTime?
  // Feature 2: scoped to a specific entity (null = group-wide access)
  entityId     String?
  createdAt    DateTime  @default(now())

  @@unique([ownerId, email])
  @@index([ownerId])
  @@index([memberId])
}

// ── SSO / SAML ────────────────────────────────────────────────────────────────

/// SSO configuration for an enterprise account (Feature 1).
model SsoConfig {
  id           String   @id @default(cuid())
  orgId        String   @unique
  provider     String            // "workos" | "saml" | "oidc"
  connectionId String            // WorkOS connection ID or SAML metadata URL
  domain       String            // e.g. "bmw.de"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ── Multi-Entity / Group Structure ────────────────────────────────────────────

/// Parent organisation that groups multiple entities/subsidiaries (Feature 2).
model Organisation {
  id        String   @id @default(cuid())
  name      String
  ownerId   String   @unique
  plan      String   @default("free")
  createdAt DateTime @default(now())
  entities  Entity[]
  owner     User     @relation(fields: [ownerId], references: [id])
}

/// A subsidiary / business unit belonging to an Organisation (Feature 2).
model Entity {
  id             String       @id @default(cuid())
  name           String
  orgId          String
  parentEntityId String?
  createdAt      DateTime     @default(now())
  organisation   Organisation @relation(fields: [orgId], references: [id])

  @@index([orgId])
}

// ── Slack / Teams Integration ─────────────────────────────────────────────────

/// Slack or Microsoft Teams notification integration per user (Feature 3).
model NotificationIntegration {
  id          String   @id @default(cuid())
  userId      String
  type        String            // "slack" | "teams"
  accessToken String?  @db.Text // encrypted, Slack only
  webhookUrl  String?  @db.Text // Teams incoming webhook URL
  channelId   String?
  channelName String?
  events      Json              // string[] of subscribed event names
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
}

// ── Connector Health Monitoring ───────────────────────────────────────────────

/// Result of a daily health probe for a REST_API or URL_SCRAPE data source (Feature 4).
model ConnectorHealthCheck {
  id           String   @id @default(cuid())
  milestoneId  String
  connectorUrl String
  status       String            // "OK" | "ERROR" | "TIMEOUT"
  httpStatus   Int?
  errorMessage String?  @db.Text
  checkedAt    DateTime @default(now())

  @@index([milestoneId])
  @@index([checkedAt])
}

// ── Deal Room ─────────────────────────────────────────────────────────────────

/// Pre-commitment due-diligence space shared between an investor and a startup (Feature 5).
model DealRoom {
  id                    String        @id @default(cuid())
  investorId            String
  startupId             String?
  inviteToken           String        @unique @default(cuid())
  status                String        @default("OPEN") // "OPEN"|"SUBMITTED"|"CONVERTED"|"DECLINED"
  aiBrief               String?       @db.Text
  briefAt               DateTime?
  convertedToContractId String?
  createdAt             DateTime      @default(now())
  documents             DealDocument[]
  investor              User          @relation("DealRoomInvestor", fields: [investorId], references: [id])

  @@index([investorId])
}

/// A document uploaded into a Deal Room (Feature 5).
model DealDocument {
  id         String   @id @default(cuid())
  dealRoomId String
  name       String
  url        String
  sha256     String
  uploadedAt DateTime @default(now())
  dealRoom   DealRoom @relation(fields: [dealRoomId], references: [id], onDelete: Cascade)

  @@index([dealRoomId])
}

// ── Contract Templates ────────────────────────────────────────────────────────

/// Reusable milestone structure saved by an investor (Feature 6).
model ContractTemplate {
  id          String   @id @default(cuid())
  creatorId   String
  name        String
  description String?
  industry    String?
  milestones  Json     // [{title, amountUSD, deadlineDays, description}]
  isPublic    Boolean  @default(false)
  useCount    Int      @default(0)
  createdAt   DateTime @default(now())
  creator     User     @relation(fields: [creatorId], references: [id])

  @@index([isPublic])
  @@index([industry])
  @@index([creatorId])
}

// ── Regulatory Change Alerts ──────────────────────────────────────────────────

/// CSRD/ESRS/GRI regulatory update fetched by the weekly cron (Feature 9).
model RegulatoryAlert {
  id           String   @id @default(cuid())
  source       String            // "EUR-LEX" | "EFRAG" | "GRI"
  title        String
  url          String
  affectedTags Json              // string[] e.g. ["CSRD:E1", "GRI:305-1"]
  severity     String            // "MINOR" | "MAJOR"
  aiSummary    String   @db.Text
  publishedAt  DateTime
  createdAt    DateTime @default(now())

  @@index([publishedAt])
}

// ── Audit Firm Partner Portal ─────────────────────────────────────────────────

/// An auditor partner account (Big 4 / audit firm) (Feature 11).
model AuditorPartner {
  id        String               @id @default(cuid())
  userId    String               @unique
  firmName  String
  createdAt DateTime             @default(now())
  user      User                 @relation(fields: [userId], references: [id])
  clients   AuditorClientAccess[]
}

/// Access grant: an enterprise user allows an auditor to view their attestations (Feature 11).
model AuditorClientAccess {
  id        String         @id @default(cuid())
  auditorId String
  clientId  String
  grantedAt DateTime       @default(now())
  revokedAt DateTime?
  auditor   AuditorPartner @relation(fields: [auditorId], references: [id])
  client    User           @relation("AuditorAccessClient", fields: [clientId], references: [id])

  @@unique([auditorId, clientId])
  @@index([auditorId])
  @@index([clientId])
}

// ── In-App Notifications ──────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String   @db.Text
  /// Optional deep-link path, e.g. "/contract/abc123"
  href      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

// ── Phase 3: Feature XI — Multi-Party Consensus Attestation ──────────────────

/// Individual vote cast by a party (AI or human) in a consensus attestation.
model ConsensusVote {
  id          String   @id @default(cuid())
  milestoneId String
  milestone   Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  partyEmail  String
  /// "AI_PLATFORM" | "AUDITOR" | "REGULATOR" | "INVESTOR" | "COMMITTEE"
  partyRole   String
  /// "YES" | "NO" | "ABSTAIN" — null while pending
  vote        String?
  reasoning   String?  @db.Text
  votedAt     DateTime?
  /// XRPL tx hash — each vote is anchored on-chain
  xrplTxHash  String?
  /// For AI_PLATFORM votes: linked AttestationEntry id
  entryId     String?
  /// One-time token sent via email to human voters
  token       String   @unique
  tokenUsed   Boolean  @default(false)
  tokenExpiry DateTime

  @@index([milestoneId])
  @@index([token])
}
